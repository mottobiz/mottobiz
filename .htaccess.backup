<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Explicitly allow all static asset paths through
  RewriteRule ^assets/ - [L]
  RewriteRule ^public/assets/ - [L]
  RewriteRule ^og/ - [L]
  RewriteRule ^public/og/ - [L]
  RewriteRule ^favicon\.svg$ - [L]
  RewriteRule ^favicon\.ico$ - [L]
  RewriteRule ^robots\.txt$ - [L]
  RewriteRule ^sitemap\.xml$ - [L]
  RewriteRule ^public/sitemap\.xml$ - [L]
  RewriteRule ^public/favicon\.svg$ - [L]
  RewriteRule ^public/robots\.txt$ - [L]
  RewriteRule ^logo.*\.(svg|png)$ - [L]

  # SPA fallback for all other routes
  RewriteRule ^ /index.html [L]
</IfModule>

# Fallback for servers without mod_rewrite
<IfModule !mod_rewrite.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
</IfModule>